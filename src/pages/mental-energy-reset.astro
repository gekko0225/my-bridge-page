---
const pageTitle = "The Brain Energy Reset";
const pageDescription =
  "Discover 5 simple ways to feel sharper, more focused, and mentally energized again.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
  </head>

  <body>
    <main class="page">
      <section class="hero">
        <div class="left-column">
          <div class="guide-preview">
            <p class="eyebrow">Free Brain Energy Guide</p>
            <h2>The Brain Energy Reset</h2>
            <p>
              5 simple ways to feel sharper, focused, and mentally energized again.
            </p>
          </div>

          <div class="form-card">
            <form
              method="post"
              accept-charset="UTF-8"
              action="https://www.aweber.com/scripts/addlead.pl"
            >
              <div style="display: none;">
                <input type="hidden" name="meta_web_form_id" value="324013429" />
                <input type="hidden" name="meta_split_id" value="" />
                <input type="hidden" name="listname" value="awlist6954858" />
                <input
                  type="hidden"
                  name="redirect"
                  value="https://growthclickslab.com/thank-you"
                />
                <input
                  type="hidden"
                  name="meta_redirect_onlist"
                  value="https://www.aweber.com/thankyou-coi.htm?m=text"
                />
                <input type="hidden" name="meta_adtracking" value="My_Web_Form" />
                <input type="hidden" name="meta_message" value="1" />
                <input type="hidden" name="meta_required" value="email" />
                <input type="hidden" name="meta_tooltip" value="" />
              </div>

              <label for="awf_field-118680048">Email</label>

              <input
                id="awf_field-118680048"
                type="email"
                name="email"
                placeholder="Your best email"
                required
              />

              <button type="submit">Get Instant Access</button>

              <p class="privacy">100% free. No spam. Unsubscribe anytime.</p>

              <div style="display: none;">
                <img
                  src="https://forms.aweber.com/form/displays.htm?id=zEwsDIzMLEyc"
                  alt=""
                />
              </div>
            </form>
          </div>
        </div>

        <div class="right-column">
          <h1>Feel Mentally Drained Lately?</h1>

          <p class="subheadline">
            Discover 5 simple ways to restore focus, clarity, and brain energy naturally.
          </p>

          <ul class="benefits">
            <li>Why your brain feels tired even after sleep</li>
            <li>Hidden daily habits that quietly kill focus</li>
            <li>A simple 10-minute brain reset routine</li>
            <li>Foods and nutrients linked to mental clarity</li>
            <li>The overlooked support many people are using today</li>
          </ul>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f4f8fb;
    --dark: #10202f;
    --text: #34495e;
    --muted: #6b7c8f;
    --white: #ffffff;
    --accent: #20c997;
    --accent-dark: #18b586;
    --blue: #1e88e5;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg);
    color: var(--text);
  }

  .page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 42px 22px;
  }

  .hero {
    width: 100%;
    max-width: 1040px;
    display: grid;
    grid-template-columns: 390px minmax(320px, 520px);
    gap: 46px;
    align-items: center;
    justify-content: center;
  }

  .left-column {
    display: grid;
    gap: 18px;
  }

  .guide-preview,
  .form-card,
  .right-column {
    background: var(--white);
    border-radius: 28px;
    box-shadow: 0 24px 70px rgba(16, 32, 47, 0.08);
  }

  .guide-preview {
    min-height: 250px;
    padding: 34px;
    background:
      radial-gradient(circle at top right, rgba(32, 201, 151, 0.25), transparent 35%),
      linear-gradient(145deg, #10202f, #1e88e5);
    color: var(--white);
  }

  .eyebrow {
    margin: 0 0 18px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .guide-preview h2 {
    margin: 0 0 16px;
    font-size: 42px;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .guide-preview p {
    margin: 0;
    font-size: 18px;
    line-height: 1.45;
    opacity: 0.92;
  }

  .form-card {
    padding: 30px;
  }

  .form-card label {
    display: block;
    margin-bottom: 10px;
    color: var(--dark);
    font-size: 16px;
    font-weight: 700;
  }

  .form-card input[type="email"] {
    width: 100%;
    height: 54px;
    border: 1px solid #d9e3ec;
    border-radius: 12px;
    padding: 0 16px;
    font-size: 16px;
    color: var(--dark);
    outline: none;
  }

  .form-card input[type="email"]:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 4px rgba(30, 136, 229, 0.12);
  }

  .form-card button {
    width: 100%;
    height: 56px;
    margin-top: 16px;
    border: 0;
    border-radius: 12px;
    background: var(--accent);
    color: var(--white);
    font-size: 18px;
    font-weight: 800;
    cursor: pointer;
    transition: 0.2s ease;
  }

  .form-card button:hover {
    background: var(--accent-dark);
    transform: translateY(-1px);
  }

  .privacy {
    margin: 14px 0 0;
    text-align: center;
    color: var(--muted);
    font-size: 13px;
  }

  .right-column {
    padding: 50px;
  }

  h1 {
    margin: 0 0 18px;
    color: var(--dark);
    font-size: clamp(38px, 5vw, 58px);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .subheadline {
    margin: 0 0 32px;
    font-size: 21px;
    line-height: 1.5;
    color: var(--text);
  }

  .benefits {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 16px;
  }

  .benefits li {
    position: relative;
    padding-left: 32px;
    font-size: 18px;
    line-height: 1.45;
  }

  .benefits li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 900;
  }

  @media (max-width: 860px) {
    .page {
      padding: 24px 16px;
      align-items: flex-start;
    }

    .hero {
      grid-template-columns: 1fr;
      gap: 20px;
      max-width: 460px;
    }

    .right-column {
      order: -1;
      padding: 30px 24px;
    }

    .guide-preview {
      min-height: 230px;
      padding: 30px 24px;
    }

    .guide-preview h2 {
      font-size: 36px;
    }

    h1 {
      font-size: 42px;
    }

    .subheadline {
      font-size: 18px;
      margin-bottom: 24px;
    }

    .benefits li {
      font-size: 16px;
    }

    .form-card {
      padding: 24px;
    }
  }
</style>