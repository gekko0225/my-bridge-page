<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Phone Trick That's Replacing 9-to-5 Jobs</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --white: #f5f0e8;
    --gold: #e8b84b;
    --gold-dark: #c49a2e;
    --red: #e84b4b;
    --gray: #1a1a1a;
    --muted: #888;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Barlow', sans-serif;
    font-size: 17px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ── TOP BAR ── */
  .topbar {
    background: var(--red);
    text-align: center;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    animation: pulse-bar 2s ease-in-out infinite;
  }
  @keyframes pulse-bar { 0%,100%{opacity:1} 50%{opacity:.85} }

  /* ── HERO ── */
  .hero {
    position: relative;
    padding: 80px 20px 60px;
    text-align: center;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(232,184,75,.18) 0%, transparent 70%);
  }
  .eyebrow {
    display: inline-block;
    background: var(--gold);
    color: var(--black);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 5px 14px;
    margin-bottom: 24px;
    clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
  }
  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(42px, 8vw, 88px);
    line-height: .95;
    letter-spacing: 1px;
    margin-bottom: 28px;
    position: relative;
  }
  h1 em {
    font-style: normal;
    color: var(--gold);
    display: block;
  }
  .sub {
    font-size: clamp(17px, 2.5vw, 21px);
    max-width: 620px;
    margin: 0 auto 40px;
    color: #ccc5b3;
    font-weight: 400;
  }
  .hero-cta {
    display: inline-block;
    background: var(--gold);
    color: var(--black);
    font-weight: 700;
    font-size: 18px;
    padding: 18px 48px;
    text-decoration: none;
    letter-spacing: .5px;
    clip-path: polygon(10px 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%);
    transition: background .2s, transform .2s;
    text-transform: uppercase;
    position: relative;
  }
  .hero-cta:hover { background: #f5cc6b; transform: translateY(-2px); }
  .hero-cta::after {
    content: ' →';
  }
  .trust-line {
    margin-top: 18px;
    font-size: 13px;
    color: var(--muted);
    letter-spacing: .5px;
  }
  .trust-line span { color: var(--gold); }

  /* ── SCROLL REVEAL ── */
  .reveal { opacity: 0; transform: translateY(30px); transition: opacity .6s ease, transform .6s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  /* ── STATS STRIP ── */
  .stats {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    border-top: 1px solid #2a2a2a;
    border-bottom: 1px solid #2a2a2a;
    background: var(--gray);
  }
  .stat {
    flex: 1;
    min-width: 140px;
    padding: 28px 24px;
    text-align: center;
    border-right: 1px solid #2a2a2a;
  }
  .stat:last-child { border-right: none; }
  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 42px;
    color: var(--gold);
    display: block;
    line-height: 1;
  }
  .stat-label { font-size: 12px; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); margin-top: 4px; }

  /* ── SECTION ── */
  section { padding: 70px 20px; max-width: 780px; margin: 0 auto; }

  h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(30px, 5vw, 52px);
    letter-spacing: 1px;
    margin-bottom: 18px;
