  .ps-card.bad h3 { color: var(--red); }
  .ps-card.good h3 { color: var(--gold); }
  .ps-card ul { list-style: none; }
  .ps-card ul li { padding: 7px 0; font-size: 15px; color: #ccc5b3; border-bottom: 1px solid #252525; }
  .ps-card ul li:last-child { border: none; }
  .ps-card.bad li::before { content: '✗  '; color: var(--red); }
  .ps-card.good li::before { content: '✓  '; color: var(--gold); }

  /* ── HOW IT WORKS ── */
  .steps { display: flex; flex-direction: column; gap: 24px; margin-top: 32px; }
